# ---- Server ----
PORT=5000
JWT_SECRET=replace_with_a_long_random_string

# Set to true to test the full signup flow WITHOUT real Twilio/Google/AWS/KYC accounts.
# In mock mode: OTP code is always 123456, Google/face/KYC steps auto-pass.
# Set to false once you plug in real provider keys below.
MOCK_MODE=true

# ---- Database (Postgres) ----
DATABASE_URL=postgresql://user:password@localhost:5432/dating_app

# ---- Phone OTP (Twilio Verify — replace with MSG91 if you prefer India-only) ----
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# ---- Google Login (Gmail) ----
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ---- Face Verification (AWS Rekognition) ----
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
REKOGNITION_COLLECTION_ID=dating_app_faces

# ---- KYC / ID Verification (e.g. HyperVerge / IDfy / Signzy) ----
KYC_PROVIDER_API_KEY=your_kyc_provider_key
KYC_PROVIDER_BASE_URL=https://api.yourkycprovider.com

# ---- Supabase (Storage & Auth Backend) ----
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

